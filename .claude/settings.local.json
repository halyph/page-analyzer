{
  "permissions": {
    "allow": [
      "Bash(go:*)",
      "Bash(git:*)",
      "Bash(make:*)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go test ./internal/domain/... -cover)",
      "Bash(git commit --amend --no-edit)",
      "Bash(go test ./internal/analyzer -run TestDebugLoginForm -v)",
      "Bash(./bin/analyzer --help)",
      "Bash(./bin/analyzer analyze --help)",
      "Bash(./bin/analyzer analyze https://example.com)",
      "Bash(./bin/analyzer analyze https://example.com --json | head -30)",
      "Bash(./bin/analyzer analyze https://go.dev --max-links 50)"
    ]
  }
}
